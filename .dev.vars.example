# Ranse build-time secrets.
#
# Every KEY listed here becomes a Worker Secret (write-only, encrypted).
# Runtime configuration (APP_URL, ADMIN_EMAIL, SUPPORT_DOMAIN, gateway
# name, etc.) lives in wrangler.jsonc `vars`, NOT here — otherwise the
# Deploy-to-Cloudflare UI prompts for the same key in two places.
#
# IMPORTANT: leave these blank. `bun run setup` fills them locally;
# `bun run deploy` generates strong random values at deploy time.

# Session + first-admin bootstrap (auto-generated if blank).
COOKIE_SIGNING_KEY=
ADMIN_BOOTSTRAP_TOKEN=

# LLM providers (BYOK). Leave all blank to use Workers AI via the `AI`
# binding; set any one to enable that provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
GROK_API_KEY=
OPENROUTER_API_KEY=

# AI Gateway auth token (optional — only needed if the gateway has
# authentication enabled; Ranse's auto-provisioned gateway does not).
CLOUDFLARE_AI_GATEWAY_TOKEN=
