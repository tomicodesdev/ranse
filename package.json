{
  "name": "ranse",
  "version": "0.1.0",
  "description": "Cloudflare-native shared inbox for support teams",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomicodesdev/ranse.git"
  },
  "homepage": "https://getranse.com",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "concurrently -n worker,ui -c blue,magenta \"wrangler dev\" \"vite\"",
    "dev:worker": "wrangler dev",
    "dev:ui": "vite",
    "build": "vite build",
    "deploy": "bun scripts/deploy.ts",
    "setup": "bun scripts/setup.ts",
    "db:migrate:local": "wrangler d1 migrations apply ranse-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ranse-db --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src scripts",
    "format": "biome format --write src scripts",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "agents": "^0.2.32",
    "hono": "^4.6.14",
    "openai": "^5.23.2",
    "postal-mime": "^2.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "jsonc-parser": "^3.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  },
  "engines": {
    "node": ">=20"
  }
}
